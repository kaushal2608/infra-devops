pipeline {
    agent any

    environment {
        IMAGE_NAME = "infra-devops"
        IMAGE_TAR = "infra-devops.tar"
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Build Docker Image') {
            steps {
                dir('app') {
                    sh 'docker build -t ${IMAGE_NAME}:latest .'
                }
            }
        }

        stage('Save Docker Image') {
            steps {
                dir('app') {
                    sh 'docker save ${IMAGE_NAME}:latest -o ${IMAGE_TAR}'
                }
            }
        }

  stage('Copy Inventory') {
    steps {
        sh '''
        cp /var/lib/jenkins/workspace/infra-pipeline/ansible/inventory ansible/inventory
        '''
    }
}

        stage('Deploy Application') {
            steps {
                sshagent(credentials: ['ec2-ssh-key']) {
                    dir('ansible') {
                        sh 'ansible-playbook deploy-app.yml'
                    }
                }
            }
        }
    }

    post {
        success {
            echo 'Application deployed successfully.'
        }

        failure {
            echo 'Application deployment failed.'
        }
    }
}