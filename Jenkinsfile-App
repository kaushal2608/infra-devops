pipeline {
    agent any
    options {
    skipDefaultCheckout(true)
}

    environment {
        IMAGE_NAME = "infra-devops"
        IMAGE_TAR = "infra-devops.tar"
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Check Changes') {
    steps {
        script {

            def changedFiles = sh(
                script: "git diff --name-only HEAD~1 HEAD",
                returnStdout: true
            ).trim()

            echo "Changed Files:"
            echo changedFiles

            if (!(changedFiles =~ /^app\//) &&
                !(changedFiles =~ /^Jenkinsfile-App$/)) {

                currentBuild.result = "NOT_BUILT"
                error("No Application changes detected.")
            }
        }
    }
}

        stage('Build Docker Image') {
            steps {
                dir('app') {
                    sh 'docker build -t ${IMAGE_NAME}:latest .'
                }
            }
        }

        stage('Save Docker Image') {
            steps {
                dir('app') {
                    sh 'docker save ${IMAGE_NAME}:latest -o ${IMAGE_TAR}'
                }
            }
        }

  stage('Copy Inventory') {
    steps {
        sh '''
        cp /var/lib/jenkins/workspace/infra-pipeline/ansible/inventory ansible/inventory
        '''
    }
}

        stage('Deploy Application') {
            steps {
                sshagent(credentials: ['ec2-ssh-key']) {
                    dir('ansible') {
                        sh 'ansible-playbook deploy-app.yml'
                    }
                }
            }
        }
    }

    post {
        success {
            echo 'Application deployed successfully.'
        }

        failure {
            echo 'Application deployment failed.'
        }
    }
}